# LM Studio Configuration
LM_STUDIO_URL=http://localhost:1234/v1
LM_STUDIO_API_KEY=lm-studio
LM_STUDIO_MODEL=gemma-3-4b
EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5

# Agent Configuration
AGENT_TEMPERATURE=0
AGENT_MAX_TOKENS=4096
AGENT_MAX_REACT_ITERATIONS=6
AGENT_MAX_SEARCH_RESULTS=8

# MITRE Query Agent (RAG-first ReAct)
# Higher-quality defaults for deeper ATT&CK analysis:
MITRE_COVERAGE_MAX_ITERATIONS=8
MITRE_RAG_PHASE_ITERATIONS=2
MITRE_RAG_MIN_CALLS=3
MITRE_SIMILARITY_THRESHOLD=0.20

# Search Configuration
SEARCH_RATE_LIMIT_MS=1500
SEARCH_REQUEST_TIMEOUT_MS=10000
WEB_SCRAPE_TIMEOUT_MS=8000
SEARCH_USER_AGENT=Mozilla/5.0

# Database
DB_PATH=./data/vendors.db

# Export
EXPORT_DIR=./reports
