{
  "name": "vendors-ai-master",
  "version": "1.0.0",
  "description": "AI-powered knowledge base for AI and cybersecurity vendor research with ReAct agent",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "server": "node --experimental-sqlite node_modules/ts-node/dist/bin.js --project tsconfig.json src/server/api.ts",
    "dev": "node --experimental-sqlite node_modules/ts-node/dist/bin.js --project tsconfig.json src/index.ts",
    "analyze": "node --experimental-sqlite node_modules/ts-node/dist/bin.js --project tsconfig.json src/index.ts analyze",
    "query": "node --experimental-sqlite node_modules/ts-node/dist/bin.js --project tsconfig.json src/index.ts query",
    "export": "node --experimental-sqlite node_modules/ts-node/dist/bin.js --project tsconfig.json src/index.ts export",
    "charts": "node --experimental-sqlite node_modules/ts-node/dist/bin.js --project tsconfig.json src/index.ts charts",
    "interactive": "node --experimental-sqlite node_modules/ts-node/dist/bin.js --project tsconfig.json src/index.ts interactive",
    "mitre:ingest": "node --experimental-sqlite node_modules/ts-node/dist/bin.js --project tsconfig.json src/index.ts mitre:ingest",
    "mitre:query":  "node --experimental-sqlite node_modules/ts-node/dist/bin.js --project tsconfig.json src/index.ts mitre:query",
    "mitre:reset":  "node --experimental-sqlite node_modules/ts-node/dist/bin.js --project tsconfig.json src/index.ts mitre:reset",
    "mitre:vendor":   "node --experimental-sqlite node_modules/ts-node/dist/bin.js --project tsconfig.json src/index.ts mitre:vendor",
    "mitre:diagnose": "node --experimental-sqlite node_modules/ts-node/dist/bin.js --project tsconfig.json src/index.ts mitre:diagnose",
    "mitre:probe":    "node --experimental-sqlite node_modules/ts-node/dist/bin.js --project tsconfig.json src/index.ts mitre:probe-embeddings",
    "paloalto:start":  "python src/paloalto-rag/main.py",
    "paloalto:install": "python -m pip install -r src/paloalto-rag/requirements.txt",
    "paloalto:ingest":  "python src/paloalto-rag/ingest_cli.py",
    "paloalto:reset":   "python src/paloalto-rag/ingest_cli.py --reset --no-defaults"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "axios": "^1.6.7",
    "chalk": "^4.1.2",
    "cheerio": "^1.0.0-rc.12",
    "cli-progress": "^3.12.0",
    "cli-table3": "^0.6.3",
    "commander": "^12.0.0",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "inquirer": "^8.2.6",
    "openai": "^4.28.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.5",
    "@types/inquirer": "^8.2.10",
    "@types/node": "^22.13.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
